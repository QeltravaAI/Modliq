generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id                       String   @id @default(auto()) @map("_id") @db.ObjectId
  name                     String?
  email                    String?   @unique
  emailVerified            DateTime?
  password                 String?
  image                    String?
  isDemo                   Boolean   @default(false)
  activeDatasetId          String?
  activeDatasetFilename    String?
  datasetAnalytics         String?
  datasetPreview           String?
  parsedIntent             String?
  activeOptimizationJobId  String?
  latestOptimizationResult String?
  healthReport             String?
  updatedAt                DateTime  @default(now()) @updatedAt

  accounts         Account[]
  sessions         Session[]
  operations       OperationsRecord[]
  suppliers        Supplier[]
  materialLots     MaterialLot[]
  leanWaste        LeanWasteEvent[]
  kaizenActions    KaizenAction[]
  fiveSAudits      FiveSAudit[]
  aiInsights       AiInsight[]
  datasets         Dataset[]
  experiments      Experiment[]
  models           Model[]
  chatSessions     ChatSession[]
  optimizationJobs OptimizationJob[]
  optimizationRuns OptimizationRun[]
  integrations     Integration[]
  aiConversations  AiConversation[]
  aiMessages       AiMessage[]
  workspaceState   WorkspaceState?
}

model Account {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Dataset {
  id                   String   @id @default(auto()) @map("_id") @db.ObjectId
  userId               String
  filename             String
  originalName         String
  filePath             String?
  contentType          String?  @default("text/csv")
  sizeBytes            Int?
  totalRows            Int?
  totalColumns         Int?
  numericColumns       Int?
  categoricalColumns   Int?
  missingValues        Int?
  duplicateRows        Int?
  constantColumns      String?
  suspiciousIdColumns  String?
  highCorrelationPairs String?
  outlierColumns       String?
  healthScore          Int?
  healthStatus         String?
  healthWarnings       String?
  healthSuggestions    String?
  analytics            String?
  preview              String?
  isDemo               Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  versions     DatasetVersion[]
  experiments  Experiment[]
  chatSessions ChatSession[]
}

model DatasetVersion {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  datasetId String
  versionId String
  data      String?
  createdAt DateTime @default(now())

  dataset Dataset @relation(fields: [datasetId], references: [id], onDelete: Cascade)

  @@unique([datasetId, versionId])
  @@index([datasetId])
}

model OptimizationJob {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String
  datasetId   String?
  status      String   @default("running")
  stage       String?
  progress    Int      @default(0)
  requestJson String?
  resultJson  String?
  error       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OptimizationRun {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  userId        String
  datasetId     String
  filename      String
  template_id   String?
  intent        String?
  monthlyVolume Float?
  unitValue     Float?
  status        String   @default("completed")
  result        String?
  error         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Experiment {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  userId          String
  datasetId       String
  name            String
  algorithm       String
  hyperparameters String?
  metrics         String?
  artifacts       String?
  modelPath       String?
  status          String   @default("completed")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  dataset Dataset @relation(fields: [datasetId], references: [id], onDelete: Cascade)
}

model Model {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  experimentId    String
  userId          String
  name            String
  description     String?
  stage           String   @default("development")
  version         Int      @default(1)
  deployEndpoint  String?
  dockerImage     String?
  apiKeyEncrypted String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  versions ModelVersion[]
}

model ModelVersion {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  modelId      String
  version      Int
  stage        String
  artifactPath String?
  metrics      String?
  changedBy    String
  changedAt    DateTime @default(now())

  model Model @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@unique([modelId, version])
  @@index([modelId])
}

model ChatSession {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String
  datasetId String
  title     String   @default("New Chat")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  dataset  Dataset       @relation(fields: [datasetId], references: [id], onDelete: Cascade)
  messages ChatMessage[]
}

model ChatMessage {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionId String
  role      String
  content   String
  metadata  String?
  createdAt DateTime @default(now())

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model Integration {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  userId     String
  type       String
  config     String?
  lastSyncAt DateTime?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OperationsRecord {
  id                    String   @id @default(auto()) @map("_id") @db.ObjectId
  userId                String
  datasetId             String?
  batchId               String?
  line                  String?
  machine               String?
  shift                 String?
  product               String?
  plannedTimeMinutes    Float?
  runtimeMinutes        Float?
  downtimeMinutes       Float?
  downtimeReason        String?
  idealCycleTimeSeconds Float?
  totalCount            Int?
  goodCount             Int?
  rejectCount           Int?
  yieldValue            Float?
  scrapRate             Float?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Supplier {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String
  name      String
  category  String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MaterialLot {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  userId         String
  supplierName   String?
  lotCode        String
  materialType   String?
  receivedDate   DateTime?
  incomingStatus String?
  defectRate     Float?
  linkedBatchId  String?
  linkedYield    Float?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LeanWasteEvent {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  userId        String
  wasteType     String
  location      String?
  description   String
  estimatedLoss Float?
  owner         String?
  status        String   @default("Open")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model KaizenAction {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  userId          String
  title           String
  problem         String?
  rootCause       String?
  countermeasure  String?
  owner           String?
  priority        String   @default("Medium")
  status          String   @default("Backlog")
  dueDate         DateTime?
  impactArea      String?
  linkedDatasetId String?
  linkedBatchId   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FiveSAudit {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String
  area        String?
  sort        Int
  setInOrder  Int
  shine       Int
  standardize Int
  sustain     Int
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AiInsight {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String
  module    String
  title     String
  summary   String
  payload   String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AiConversation {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AiMessage {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  userId         String
  conversationId String
  role           String
  content        String
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WorkspaceState {
  userId                   String   @id @map("_id") @db.ObjectId
  activeDatasetId          String?
  activeWorkflowId         String?
  activeDatasetFilename    String?
  datasetAnalytics         String?
  datasetPreview           String?
  parsedIntent             String?
  activeOptimizationJobId  String?
  latestOptimizationResult String?
  healthReport             String?
  updatedAt                DateTime @default(now()) @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
